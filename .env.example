# ── Copy this file to .env for local development ──
# Never commit .env to git!

# Security
SECRET_KEY=change-this-to-a-random-long-string

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# App URL (your deployed URL)
APP_URL=http://localhost:5000

# Database (leave blank for SQLite in development)
# DATABASE_URL=postgresql://user:password@host/dbname

# ── WhatsApp via Twilio ──
# Sign up free at https://www.twilio.com
# Free trial gives $15 credit (~1000 WhatsApp messages)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP=whatsapp:+14155238886
TWILIO_PHONE=+1234567890

# ── SMS via Fast2SMS (India - very cheap) ──
# Sign up at https://www.fast2sms.com
# Rs.10 = ~500 SMS messages
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# Reminder days before due date
REMINDER_DAYS_BEFORE=3

# Debug mode (never enable in production)
FLASK_DEBUG=0
